<Page x:Class="P26_002_Pultral.Pages.ProductListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:P26_002_Pultral.Controls"
      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d"
      d:DesignHeight="1080"
      d:DesignWidth="1920"
      Title="ProductListPage"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="451*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="151*"/>
            <ColumnDefinition Width="79*"/>
        </Grid.ColumnDefinitions>
        <Border Background="#66F8F8FF"
                BorderBrush="{StaticResource LightBorderBrush}"
                BorderThickness="1" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Blue title bar containing the search box -->
                <Border Grid.Row="0"
                        Background="{StaticResource PrimaryBrandBrush}"
                        Padding="24,14">
                    <Grid>
                        <TextBox x:Name="SearchTextBox"
                                 Height="46" FontSize="18"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchTextBox_TextChanged"/>
                        <TextBlock IsHitTestVisible="False"
                                   Text="Rechercher un produit, item ou no de job..."
                                   VerticalAlignment="Center"
                                   Margin="12,0"
                                   FontSize="18" FontStyle="Italic"
                                   Foreground="{StaticResource SecondaryTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Table header -->
                <Border Grid.Row="1"
                        Background="#F0F3F7"
                        BorderBrush="{StaticResource LightBorderBrush}"
                        BorderThickness="1,1,1,0"
                        Margin="24,16,24,0">
                    <Grid Height="44" Margin="0,0,17,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.6*"/>
                            <ColumnDefinition Width="0.75*"/>
                            <ColumnDefinition Width="0.75*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Description de l'Item" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Padding="12,0"/>
                        <TextBlock Grid.Column="1" Text="Item"                  FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Padding="12,0"/>
                        <TextBlock Grid.Column="2" Text="No de Job"             FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Padding="12,0"/>
                        <TextBlock Grid.Column="3" Text="Qte Imprimee"          FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Padding="4,0" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="4" Text="Nbr de Bundles"        FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Padding="4,0" TextWrapping="Wrap"/>
                        <TextBlock Grid.Column="5" Text="Nbr Etiquettes"        FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center" Padding="4,0" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Item list -->
                <ListBox x:Name="ProductsListBox" Grid.Row="2"
                         Margin="24,0,24,0"
                         BorderThickness="1" Padding="0" FontSize="18"
                         BorderBrush="{StaticResource LightBorderBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Visible">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"                    Value="0,6"/>
                            <Setter Property="Margin"                     Value="0"/>
                            <Setter Property="BorderBrush"                Value="{StaticResource LightBorderBrush}"/>
                            <Setter Property="BorderThickness"            Value="0,0,0,1"/>
                            <Setter Property="Background"                 Value="White"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"  Value="#E8F0FA"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrandBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <controls:ProductItemControl/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Equal-width buttons filling the full bottom width -->
                <Grid Grid.Row="3" Margin="24,16,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Ajouter des Produits"    Style="{StaticResource SuccessButtonStyle}" Click="AddProductsButton_Click"   FontSize="20" Padding="0,20"/>
                    <Button Grid.Column="1" Content="Valider les impressions" Style="{StaticResource PrimaryButtonStyle}" Click="ValidatePrintsButton_Click" FontSize="20" Padding="0,20"/>
                    <Button Grid.Column="2" Content="Imprimer"                                                           Click="PrintButton_Click"           FontSize="20" Padding="0,20"/>
                    <Button Grid.Column="3" Width="64" Height="64" Margin="6" Padding="0"
                            Click="ConnectionTestButton_Click" VerticalAlignment="Center"
                            ToolTip="Tester l'état des connexions">
                        <iconPacks:PackIconMaterial Kind="Wifi" Width="30" Height="30"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
