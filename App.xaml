<Application x:Class="P26_002_Pultral.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:P26_002_Pultral"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrandBrush" Color="#2D5582"/>
        <SolidColorBrush x:Key="AccentSuccessBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="ErrorAlertBrush" Color="#D32F2F"/>
        <SolidColorBrush x:Key="AlarmBlueBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CCF8F8FF"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="LightBorderBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="MediumBorderBrush" Color="#888888"/>
        <SolidColorBrush x:Key="StrongBorderBrush" Color="#000000"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#000000"/>
        <SolidColorBrush x:Key="OnDarkTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>

        <ImageBrush x:Key="AppBackgroundBrush" ImageSource="/Background/BGRevtechLight.png" Stretch="UniformToFill"/>

        <Style TargetType="Window">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style TargetType="Page">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource LightBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MediumBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrandBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnDarkTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrandBrush}"/>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentSuccessBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnDarkTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentSuccessBrush}"/>
        </Style>

        <Style x:Key="ErrorButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource ErrorAlertBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource OnDarkTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ErrorAlertBrush}"/>
        </Style>
    </Application.Resources>
</Application>
