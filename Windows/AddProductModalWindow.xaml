<Window x:Class="P26_002_Pultral.Windows.AddProductModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Ajouter des produits"
        Height="440"
        Width="840"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F8F8FF">
    <Grid Margin="36">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="139*"/>
            <ColumnDefinition Width="536*"/>
            <ColumnDefinition Width="91*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PrimaryBrandBrush}" Padding="16,10" Margin="-36,-36,-36,0" Grid.ColumnSpan="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Num&#233;ro de Commande"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OnDarkTextBrush}"
                           Grid.ColumnSpan="1"/>
                <Button
                        x:Name="ManualInputButton"
                        Width="54" Height="32"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        ToolTip="Mode de saisie manuelle"
                        Click="ManualInputButton_Click"
                        BorderThickness="0" 
                        Background="{DynamicResource OnDarkTextBrush}" BorderBrush="{DynamicResource StrongBorderBrush}" Grid.Column="2">
                    <iconPacks:PackIconMaterial Kind="KeyboardOutline" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <TextBox x:Name="ProductNameTextBox"
                 Grid.Row="1"
                 Margin="0,16,0,251"
                 FontSize="24"
                 MinWidth="640" Grid.ColumnSpan="4" Grid.RowSpan="2"/>

        <UniformGrid Grid.Row="2" Rows="1" Columns="2" Margin="0,128,0,0" Grid.ColumnSpan="4">
            <Button x:Name="ConfirmButton" Content="Confirmer" Style="{StaticResource SuccessButtonStyle}" FontSize="24" Padding="0,16" Click="ConfirmButton_Click" IsDefault="True"/>
            <Button x:Name="CancelButton"  Content="Annuler"   Style="{StaticResource ErrorButtonStyle}"   FontSize="24" Padding="0,16" Click="CancelButton_Click"/>
        </UniformGrid>
    </Grid>
</Window>